

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Movies Index</title>
    <link href="https://fonts.googleapis.com/css2?family=Anton&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <style>
      body { background-color: #F8F9FA; color: #222222; font-family: 'Roboto', sans-serif; display: flex; flex-direction: column; min-height: 100vh; margin: 0; padding: 24px; box-sizing: border-box; }
      header h1 { font-family: 'Anton', sans-serif; color: #5B21B6; }
      form { display: flex; flex-direction: column; gap: 12px; max-width: 400px; }
      a, button { color: #5B21B6; background: none; border: 1px solid #5B21B6; padding: 6px 14px; text-decoration: none; font-family: 'Roboto', sans-serif; cursor: pointer; font-size: 14px; align-self: flex-start; }
    </style>
  </head>
 <body>
  <header>
    <h1>Moviecure</h1>
  </header>
  <h1>All Movies</h1>
  <ul>
    <% movies.forEach(movie => { %>
      <li>
        <a href="/movies/<%= movie._id %>"> <%= movie.name %> </a>
        - <%=
          movie.rating === 6 ? '🤩All Time Fav🏆' :
          movie.rating === 5 ? '😍Amazing🔥' :
          movie.rating === 4 ? '😄Great⭐️' :
          movie.rating === 3 ? '😐Solid👍' :
          movie.rating === 2 ? '😕Not Great⚠️' :
          movie.rating === 1 ? '🤢Horrible🗑️' : ''
        %>
      </li>
    <% }); %>
  </ul>
  <a href="/">Home</a>
  <a href="/movies/new">Add New Review</a>
  <a href="/recommendations">My Recommendations</a>
  <a href="/auth/sign-out">Sign out</a>
  </body>
</html>
